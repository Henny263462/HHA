{
  "model": {
    "type": "minecraft:condition",
    "property": "minecraft:custom_model_data",
    "index": 0,
    "on_true": {
      "type": "minecraft:model",
      "model": "hha:item/heavens_mace_thrown"
    },
    "on_false": {
      "type": "minecraft:condition",
      "property": "minecraft:has_component",
      "component": "minecraft:enchantments",
      "ignore_default": true,
      "on_true": { "type": "minecraft:model", "model": "hha:item/heavens_mace_ench" },
      "on_false": { "type": "minecraft:model", "model": "hha:item/heavens_mace" }
    }
  }
}
